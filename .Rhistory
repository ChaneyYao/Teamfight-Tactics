library(stringr)
?gsub
library(grep)
rate_cal = function(input_col){
x = input_col
no_percent_x = gsub("%", "", x)
num_x = as.numeric(no_percent_x) / 100
return(num_x)
}
# The main data with some pro
main_dt = test[[13]] %>%
mutate("Win%" = rate_cal(`Win%`),
"Top4%" = rate_cal(`Top4%`),
"8th%" = rate_cal(`8th%`))
?as.numeric
rate_cal = function(input_col){
x = input_col
no_percent_x = gsub("%", "", x)
num_x = as.numeric(no_percent_x, length = 2) / 100
return(num_x)
}
main_dt = test[[13]] %>%
mutate("Win%" = rate_cal(`Win%`),
"Top4%" = rate_cal(`Top4%`),
"8th%" = rate_cal(`8th%`))
table(main_dt$Region, main_dt$`Top4%`)
